---
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";
import Media from "../../components/Media.astro";
import PheroCanvas from "../../components/PheroCanvas.astro";
import { getAboutPage } from "../../lib/site";
import { altOf, localeStaticPaths, otherLocale } from "../../i18n";
import { t } from "../../i18n/ui";

export function getStaticPaths() {
  return localeStaticPaths();
}

const { locale } = Astro.props;
const alt = otherLocale(locale);
const tr = t(locale);
const trA = t(alt);
const about = await getAboutPage(locale);
const aboutAlt = await getAboutPage(alt);
const capRange = `( 01 — ${String(about.capabilities.length).padStart(2, "0")} )`;
const procRange = `( 01 — ${String(about.process.length).padStart(2, "0")} )`;
---

<Base
  title={about.metaTitle}
  description={about.lede}
  titleAlt={aboutAlt.metaTitle}
  locale={locale}
>
  <!-- PAGE HERO -->
  <section
    class="phero"
    data-screen-label={tr.sections.aboutHero}
    data-screen-label-alt={altOf(tr.sections.aboutHero, trA.sections.aboutHero)}
  >
    <PheroCanvas locale={locale} />
    <div class="phero__index meta">
      <span data-scramble-now data-text={tr.aboutScramble} data-i18n-alt={altOf(tr.aboutScramble, trA.aboutScramble)}
        >{tr.aboutScramble}</span
      ><span class="rule"></span><span
        data-i18n-alt={altOf(`${tr.indexLabel} 01`, `${trA.indexLabel} 01`)}
        >{tr.indexLabel} 01</span
      >
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise data-i18n-alt={altOf(about.title, aboutAlt.title)}>{about.title}</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft data-i18n-alt={altOf(about.lede, aboutAlt.lede)}>{about.lede}</p>
      <span class="meta" data-rise-soft data-i18n-alt={altOf(about.subMeta, aboutAlt.subMeta)}>{about.subMeta}</span>
    </div>
  </section>

  <!-- INTRO QUOTE -->
  <section class="about-intro">
    <blockquote class="about-intro__quote reveal-lines">
      {
        about.introQuote.map((line, i) => (
          <span class="line">
            <span set:html={line} data-i18n-html data-i18n-alt={altOf(line, aboutAlt.introQuote[i] ?? line)} />
          </span>
        ))
      }
    </blockquote>
  </section>

  <!-- BIO -->
  <section class="about-cols">
    <div class="about-cols__label meta" data-i18n-alt={altOf(tr.bioLabel, trA.bioLabel)}>{tr.bioLabel}</div>
    <div class="about-cols__body">
      {about.bio.map((para, i) => <p set:html={para} data-i18n-html data-i18n-alt={altOf(para, aboutAlt.bio[i] ?? para)} />)}
    </div>
  </section>

  <!-- PORTRAIT -->
  <section class="about-portrait">
    <div class="frame">
      <Media src={about.portrait} label={about.portraitCaption} />
    </div>
    <div class="cap meta">
      <span data-i18n-alt={altOf(about.portraitCaption, aboutAlt.portraitCaption)}>{about.portraitCaption}</span><span>{about.portraitYear}</span>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <details class="idx-list">
    <summary class="idx-list__head">
      <span class="fold-chev" aria-hidden="true"></span>
      <h2 data-scramble data-i18n-alt={altOf(about.capabilitiesHeading, aboutAlt.capabilitiesHeading)}>{about.capabilitiesHeading}</h2>
      <span class="meta">{capRange}</span>
    </summary>
    {
      about.capabilities.map((c, i) => (
        <div class="idx-row" data-reveal>
          <span class="n">{String(i + 1).padStart(2, "0")}</span>
          <span class="t" data-scramble data-i18n-alt={altOf(c.title, aboutAlt.capabilities[i]?.title ?? c.title)}>
            {c.title}
          </span>
          <span class="d" data-i18n-alt={altOf(c.detail, aboutAlt.capabilities[i]?.detail ?? c.detail)}>{c.detail}</span>
        </div>
      ))
    }
  </details>

  <!-- PROCESS -->
  <details
    class="idx-list"
    style="margin-top:clamp(60px,10vh,120px)"
    data-screen-label={tr.sections.aboutProcess}
    data-screen-label-alt={altOf(tr.sections.aboutProcess, trA.sections.aboutProcess)}
  >
    <summary class="idx-list__head">
      <span class="fold-chev" aria-hidden="true"></span>
      <h2 data-scramble data-i18n-alt={altOf(about.processHeading, aboutAlt.processHeading)}>{about.processHeading}</h2>
      <span class="meta">{procRange}</span>
    </summary>
    {
      about.process.map((c, i) => (
        <div class="idx-row" data-reveal>
          <span class="n">{String(i + 1).padStart(2, "0")}</span>
          <span class="t" data-scramble data-i18n-alt={altOf(c.title, aboutAlt.process[i]?.title ?? c.title)}>
            {c.title}
          </span>
          <span class="d" data-i18n-alt={altOf(c.detail, aboutAlt.process[i]?.detail ?? c.detail)}>{c.detail}</span>
        </div>
      ))
    }
  </details>

  <!-- RECOGNITION -->
  <details class="idx-list" style="margin-top:clamp(60px,10vh,120px)">
    <summary class="idx-list__head">
      <span class="fold-chev" aria-hidden="true"></span>
      <h2 data-scramble data-i18n-alt={altOf(about.recognitionHeading, aboutAlt.recognitionHeading)}>{about.recognitionHeading}</h2>
      <span class="meta" data-i18n-alt={altOf(tr.selectedLabel, trA.selectedLabel)}>{tr.selectedLabel}</span>
    </summary>
    {
      about.recognition.map((r, i) => (
        <div class="idx-row" data-reveal>
          <span class="n">—</span>
          <span class="t" data-scramble data-i18n-alt={altOf(r.title, aboutAlt.recognition[i]?.title ?? r.title)}>
            {r.title}
          </span>
          <span class="d" data-i18n-alt={altOf(r.detail, aboutAlt.recognition[i]?.detail ?? r.detail)}>{r.detail}</span>
        </div>
      ))
    }
  </details>

  <!-- TECHNOLOGIES -->
  {
    about.technologies.length > 0 && (
      <details class="idx-list" style="margin-top:clamp(60px,10vh,120px)">
        <summary class="idx-list__head">
          <span class="fold-chev" aria-hidden="true" />
          <h2 data-scramble data-i18n-alt={altOf(tr.technologiesHeading, trA.technologiesHeading)}>
            {tr.technologiesHeading}
          </h2>
        </summary>
        <ul class="tech" tabindex="0" aria-label={tr.technologiesHeading}>
          {about.technologies.map((tech) => (
            <li class="tech__item">
              {/* inline <svg> (not Media.astro) so fill="currentColor" inherits the text color */}
              <span class="tech__logo" set:html={tech.svg} aria-hidden="true" />
              <span class="tech__name meta">{tech.name}</span>
            </li>
          ))}
        </ul>
        {/* thin scroll indicator — horizontal twin of the page scrollbar */}
        <div class="tech-scroll" aria-hidden="true">
          <div class="tech-scroll__thumb"></div>
        </div>
      </details>
    )
  }

  <Footer locale={locale} />
</Base>

<script is:inline>
  // Technologies-strip scroll indicator — mirrors the page scrollbar wired in
  // core.js: the native bar is hidden in CSS, this thin thumb tracks progress.
  // Same measure/update split: geometry off the scroll hot path.
  (function () {
    const strip = document.querySelector(".tech");
    const bar = document.querySelector(".tech-scroll");
    const thumb = bar && bar.querySelector(".tech-scroll__thumb");
    if (!strip || !thumb) return;
    let trackW = 0, thumbW = 0;
    function measure() {
      const overflows = strip.scrollWidth > strip.clientWidth;
      trackW = bar.clientWidth;
      thumbW = Math.max(24, trackW * (strip.clientWidth / strip.scrollWidth));
      thumb.style.width = thumbW + "px";
      bar.classList.toggle("is-ready", overflows); // hide when nothing to scroll
    }
    function update() {
      const max = strip.scrollWidth - strip.clientWidth;
      const p = max > 0 ? strip.scrollLeft / max : 0;
      thumb.style.transform = "translateX(" + p * (trackW - thumbW) + "px)";
    }
    measure();
    update();
    // The strip sits inside a collapsed <details>; geometry is 0 until it
    // opens, so re-measure on every toggle.
    const fold = strip.closest("details");
    if (fold) fold.addEventListener("toggle", function () { measure(); update(); });
    strip.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", function () {
      measure();
      update();
    });

    // Click / drag on the track — same semantics as the page rail (core.js):
    // a click jumps (thumb centered on the pointer), the gesture keeps
    // dragging. Snap is suspended while dragging so the thumb doesn't fight
    // the strip's mandatory snap points; it re-engages on release.
    let grab = -1; // pointer offset inside the thumb while dragging (px); -1 = idle
    function dragTo(clientX) {
      const range = trackW - thumbW;
      const max = strip.scrollWidth - strip.clientWidth;
      if (range <= 0 || max <= 0) return;
      const rect = bar.getBoundingClientRect();
      const p = Math.min(1, Math.max(0, (clientX - rect.left - grab) / range));
      strip.scrollLeft = p * max;
    }
    bar.addEventListener("pointerdown", function (e) {
      e.preventDefault(); // no text selection / touch scroll while dragging
      const t = thumb.getBoundingClientRect();
      grab = e.clientX >= t.left && e.clientX <= t.right ? e.clientX - t.left : thumbW / 2;
      strip.style.scrollSnapType = "none";
      bar.setPointerCapture(e.pointerId);
      dragTo(e.clientX);
    });
    bar.addEventListener("pointermove", function (e) {
      if (grab >= 0) dragTo(e.clientX);
    });
    function endDrag() {
      grab = -1;
      strip.style.scrollSnapType = "";
    }
    bar.addEventListener("pointerup", endDrag);
    bar.addEventListener("pointercancel", endDrag);
  })();

  // Expanding/collapsing a section changes the page height — recompute the
  // ScrollTrigger positions core.js registered (Lenis resizes itself via its
  // own ResizeObserver).
  document.querySelectorAll("details.idx-list").forEach(function (d) {
    d.addEventListener("toggle", function () {
      if (window.ScrollTrigger) ScrollTrigger.refresh();
    });
    // the height keeps changing until the ::details-content transition ends —
    // refresh again once it settles so trigger positions match the final layout
    d.addEventListener("transitionend", function (e) {
      if (e.pseudoElement === "::details-content" && window.ScrollTrigger) ScrollTrigger.refresh();
    });
  });
</script>
