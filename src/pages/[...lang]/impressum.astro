---
import LegalPage from "../../components/LegalPage.astro";
import { getImpressumPage } from "../../lib/legal";
import { localeStaticPaths, otherLocale } from "../../i18n";
import { t } from "../../i18n/ui";

export function getStaticPaths() {
  return localeStaticPaths();
}

const { locale } = Astro.props;
const alt = otherLocale(locale);
const page = await getImpressumPage(locale);
const pageAlt = await getImpressumPage(alt);
---

<LegalPage
  locale={locale}
  page={page}
  pageAlt={pageAlt}
  sideLabel={t(locale).navImpressum}
  sideLabelAlt={t(alt).navImpressum}
/>
