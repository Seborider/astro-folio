---
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";
import { getImpressumPage } from "../../lib/impressum";
import { localeStaticPaths } from "../../i18n";
import { t } from "../../i18n/ui";

export function getStaticPaths() {
  return localeStaticPaths();
}

const { locale } = Astro.props;
const tr = t(locale);
const page = await getImpressumPage(locale);
const scramble = `( ${page.title} )`;
---

<Base title={page.metaTitle} description={page.lede} locale={locale}>
  <!-- PAGE HERO -->
  <section class="phero" data-screen-label={page.title}>
    <div class="phero__index meta">
      <span data-scramble-now data-text={scramble}>{scramble}</span><span
        class="rule"></span><span>{tr.indexLabel}</span>
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise>{page.title}</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft>{page.lede}</p>
    </div>
  </section>

  <!-- BODY -->
  <section class="about-cols">
    <div class="about-cols__label meta">( {tr.navImpressum} )</div>
    <div class="about-cols__body">
      {page.body.map((p) => <p set:html={p} />)}
    </div>
  </section>

  <Footer locale={locale} />
</Base>
