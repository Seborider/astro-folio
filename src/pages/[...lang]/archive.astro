---
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";
import { getProjects } from "../../lib/projects";
import { localePath, localeStaticPaths } from "../../i18n";
import { t } from "../../i18n/ui";

export function getStaticPaths() {
  return localeStaticPaths();
}

const { locale } = Astro.props;
const tr = t(locale);
const projects = await getProjects(locale);
const first = projects[0]?.yr ?? "";
const last = projects[projects.length - 1]?.yr ?? "";
---

<Base
  title={tr.archiveMetaTitle}
  description={tr.archiveDescription}
  locale={locale}
>
  <!-- PAGE HERO -->
  <section class="phero" data-screen-label="Archive hero">
    <div class="phero__index meta">
      <span data-scramble-now data-text={tr.archiveScramble}
        >{tr.archiveScramble}</span
      ><span class="rule"></span><span>Index 03</span>
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise>{tr.archiveTitle}</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft>{tr.archiveLede}</p>
      <span class="meta" data-rise-soft>( {last} — {first} )</span>
    </div>
  </section>

  <!-- TABLE -->
  <section class="arch" data-screen-label="Archive table">
    <div class="arch__table">
      <div class="arch__row head">
        <span>{tr.thYear}</span><span>{tr.thProject}</span><span
          >{tr.thType}</span
        ><span>{tr.thRole}</span><span style="text-align:right"
          >{tr.thLink}</span
        >
      </div>
      {
        projects.map((p) => (
          <a
            class="arch__row"
            data-cursor="open"
            href={localePath(locale, `/work/${p.id}`)}
          >
            <span class="yr">{p.yr}</span>
            <span class="ttl" data-scramble>
              {p.name}
            </span>
            <span class="ty">{p.cat}</span>
            <span class="ro">{p.role}</span>
            <span class="lk">{tr.viewLink}</span>
          </a>
        ))
      }
    </div>
  </section>

  <Footer locale={locale} />
</Base>
