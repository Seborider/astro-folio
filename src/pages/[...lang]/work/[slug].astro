---
import Base from "../../../layouts/Base.astro";
import Footer from "../../../components/Footer.astro";
import Media from "../../../components/Media.astro";
import { getProjects, neighbours } from "../../../lib/projects";
import { DEFAULT_LOCALE, LOCALES, localePath, pageTitle } from "../../../i18n";
import { t } from "../../../i18n/ui";

export async function getStaticPaths() {
  // Locale cross-product: each project page exists at /work/<slug> (de)
  // and /en/work/<slug>. Slugs are shared; only the text differs.
  const paths = [];
  for (const locale of LOCALES) {
    const projects = await getProjects(locale);
    const n = projects.length;
    paths.push(
      ...projects.map((entry, i) => ({
        params: {
          lang: locale === DEFAULT_LOCALE ? undefined : locale,
          slug: entry.id,
        },
        props: {
          locale,
          entry,
          index: i,
          total: n,
          ...neighbours(projects, i),
        },
      })),
    );
  }
  return paths;
}

const { locale, entry, index, total, prev, next } = Astro.props;
const tr = t(locale);
const p = entry;
const coverLabel = p.gallery[0]
  ? `${p.name} — ${p.gallery[0].label.replace(/ — .*/, "")}`
  : p.name;
const metaRows: [string, string][] = [
  [tr.metaClient, p.client],
  [tr.metaYear, p.yr],
  [tr.metaRole, p.role],
  [tr.metaServices, p.services.join(", ")],
];
---

<Base title={pageTitle(p.name)} description={p.intro} locale={locale}>
  <!-- HERO -->
  <section class="pd-hero" data-screen-label={tr.sections.projectHero}>
    <div class="phero__index meta">
      <span>( {p.cat} )</span><span class="rule"></span>
      <span
        >{String(index + 1).padStart(2, "0")} / {
          String(total).padStart(2, "0")
        }</span
      >
    </div>
    <h1 class="pd-title">
      <span class="line"><span data-rise>{p.name}</span></span>
    </h1>
    <div class="pd-sub">
      <p class="pd-lede" data-rise-soft>{p.intro}</p>
      <span class="pd-tags meta" data-rise-soft>{p.cat} — {p.yr}</span>
    </div>
  </section>

  <!-- COVER -->
  <section class="pd-cover">
    <div class="frame"><Media src={p.cover} label={coverLabel} /></div>
  </section>

  <!-- INFO -->
  <section class="pd-info" data-screen-label={tr.sections.projectInfo}>
    <div class="pd-info__meta">
      {
        metaRows.map(([k, v]) => (
          <div class="pd-meta-row">
            <>
              <span class="k">{k}</span>
              <span class="v">{v}</span>
            </>
          </div>
        ))
      }
    </div>
    <div class="pd-info__body">
      {p.overview.map((t) => <p>{t}</p>)}
    </div>
  </section>

  <!-- GALLERY -->
  <section class="pd-gallery" data-screen-label={tr.sections.projectGallery}>
    {
      p.gallery.map((g, i) => (
        <figure class={`pd-shot ${g.span}`} data-reveal>
          <Media src={g.image} label={g.label} />
          <figcaption class="meta">
            {String(i + 1).padStart(2, "0")} — {g.label}
          </figcaption>
        </figure>
      ))
    }
  </section>

  <!-- QUOTE (optional) -->
  {
    p.quote && p.quote.length > 0 && (
      <blockquote class="pd-quote reveal-lines">
        {p.quote.map((line) => (
          <span class="line">
            <span set:html={line} />
          </span>
        ))}
      </blockquote>
    )
  }

  <!-- PREV / NEXT -->
  <nav class="pd-next">
    <a
      class="pd-nav-link prev"
      href={localePath(locale, `/work/${prev.id}`)}
      data-cursor="open"
    >
      <span class="meta">{tr.prevLabel}</span><span class="t">{prev.name}</span>
    </a>
    <a
      class="pd-nav-link next"
      href={localePath(locale, `/work/${next.id}`)}
      data-cursor="open"
    >
      <span class="meta">{tr.nextLabel}</span><span class="t">{next.name}</span>
    </a>
  </nav>

  <Footer locale={locale} />
</Base>
