---
import Base from "../../../layouts/Base.astro";
import Footer from "../../../components/Footer.astro";
import Media from "../../../components/Media.astro";
import Showreel from "../../../components/Showreel.astro";
import PheroCanvas from "../../../components/PheroCanvas.astro";
import { getProjects, neighbours } from "../../../lib/projects";
import { altOf, BRAND, DEFAULT_LOCALE, LOCALES, localePath, otherLocale, pageTitle } from "../../../i18n";
import { t } from "../../../i18n/ui";
import { creativeWorkSchema } from "../../../lib/jsonld";

export async function getStaticPaths() {
  // Locale cross-product: each project page exists at /work/<slug> (de)
  // and /en/work/<slug>. Slugs are shared; only the text differs. The alt-
  // locale entry/neighbours ride along so the page can be swapped in place.
  const paths = [];
  for (const locale of LOCALES) {
    const alt = otherLocale(locale);
    const projects = await getProjects(locale);
    const projectsAlt = await getProjects(alt);
    const n = projects.length;
    paths.push(
      ...projects.map((entry, i) => {
        const nb = neighbours(projects, i);
        const nbAlt = neighbours(projectsAlt, i);
        return {
          params: {
            lang: locale === DEFAULT_LOCALE ? undefined : locale,
            slug: entry.id,
          },
          props: {
            locale,
            entry,
            index: i,
            total: n,
            ...nb,
            entryAlt: projectsAlt[i],
            prevAlt: nbAlt.prev,
            nextAlt: nbAlt.next,
          },
        };
      }),
    );
  }
  return paths;
}

const { locale, entry, index, total, prev, next, entryAlt, prevAlt, nextAlt } =
  Astro.props;
const alt = otherLocale(locale);
const tr = t(locale);
const trA = t(alt);
const p = entry;
const pA = entryAlt;
const coverLabel = p.gallery[0]
  ? `${p.name} — ${p.gallery[0].label.replace(/ — .*/, "")}`
  : p.name;
// [label, value, labelAlt, valueAlt] — yr isn't localized, only its label is.
const metaRows: [string, string, string, string][] = [
  [tr.metaClient, p.client, trA.metaClient, pA.client],
  [tr.metaYear, p.yr, trA.metaYear, pA.yr],
  [tr.metaRole, p.role, trA.metaRole, pA.role],
  [tr.metaServices, p.services.join(", "), trA.metaServices, pA.services.join(", ")],
  ...(p.technologies.length
    ? [[tr.metaTech, p.technologies.join(", "), trA.metaTech, pA.technologies.join(", ")] as [string, string, string, string]]
    : []),
];
const jsonLd = creativeWorkSchema({
  name: p.name,
  url: new URL(localePath(locale, `/work/${p.id}`), Astro.site).href,
  description: p.intro,
  image: p.cover,
  dateCreated: p.yr,
  inLanguage: locale,
  author: { name: BRAND, url: new URL(localePath(locale, "/"), Astro.site).href },
});
---

<Base
  title={pageTitle(p.name)}
  description={p.intro}
  titleAlt={pageTitle(pA.name)}
  image={p.cover}
  locale={locale}
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section
    class="pd-hero"
    data-screen-label={tr.sections.projectHero}
    data-screen-label-alt={altOf(tr.sections.projectHero, trA.sections.projectHero)}
  >
    <PheroCanvas locale={locale} />
    <div class="phero__index meta">
      <span>( <span data-i18n-alt={altOf(p.cat, pA.cat)}>{p.cat}</span> )</span><span class="rule"></span>
      <span
        >{String(index + 1).padStart(2, "0")} / {
          String(total).padStart(2, "0")
        }</span
      >
    </div>
    <h1 class="pd-title">
      <span class="line"><span data-rise data-i18n-alt={altOf(p.name, pA.name)}>{p.name}</span></span>
    </h1>
    <div class="pd-sub">
      <div class="pd-lede-col">
        <p class="pd-lede" data-rise-soft data-i18n-alt={altOf(p.intro, pA.intro)}>{p.intro}</p>
        {p.ledeLink && (
          <a
            class="pd-lede-link meta"
            href={p.ledeLink.url}
            target="_blank"
            rel="noopener"
            data-cursor="view"
            data-rise-soft
          >{p.ledeLink.label}</a>
        )}
      </div>
      <span class="pd-tags meta" data-rise-soft><span data-i18n-alt={altOf(p.cat, pA.cat)}>{p.cat}</span> — {p.yr}</span>
    </div>
  </section>

  <!-- COVER -->
  <section class="pd-cover">
    <div class="frame"><Media src={p.cover} label={coverLabel} /></div>
    {p.video && (
      <div class="reel__cta" data-rise-soft>
        <button data-video={p.video} data-cursor="play" data-magnetic
          ><span class="tri"></span> <span data-i18n-alt={altOf(tr.playVideo, trA.playVideo)}>{tr.playVideo}</span></button
        >
      </div>
    )}
  </section>

  <!-- INFO -->
  <section
    class="pd-info"
    data-screen-label={tr.sections.projectInfo}
    data-screen-label-alt={altOf(tr.sections.projectInfo, trA.sections.projectInfo)}
  >
    <div class="pd-info__meta">
      {
        metaRows.map(([k, v, kA, vA]) => (
          <div class="pd-meta-row">
            <>
              <span class="k" data-i18n-alt={altOf(k, kA)}>{k}</span>
              <span class="v" data-i18n-alt={altOf(v, vA)}>{v}</span>
            </>
          </div>
        ))
      }
    </div>
    <div class="pd-info__body">
      {p.overview.map((para, i) => <p data-i18n-alt={altOf(para, pA.overview[i] ?? para)}>{para}</p>)}
    </div>
  </section>

  <!-- GALLERY -->
  <section
    class="pd-gallery"
    data-screen-label={tr.sections.projectGallery}
    data-screen-label-alt={altOf(tr.sections.projectGallery, trA.sections.projectGallery)}
  >
    {
      p.gallery.map((g, i) => (
        <figure class={`pd-shot ${g.span}`} data-reveal>
          <Media src={g.image} label={g.label} />
          <figcaption class="meta">
            {String(i + 1).padStart(2, "0")} — <span data-i18n-alt={altOf(g.label, pA.gallery[i]?.label ?? g.label)}>{g.label}</span>
          </figcaption>
        </figure>
      ))
    }
  </section>

  <!-- QUOTE (optional) -->
  {
    p.quote && p.quote.length > 0 && (
      <blockquote class="pd-quote reveal-lines">
        {p.quote.map((line, i) => (
          <span class="line">
            <span set:html={line} data-i18n-html data-i18n-alt={altOf(line, pA.quote?.[i] ?? line)} />
          </span>
        ))}
      </blockquote>
    )
  }

  <!-- PREV / NEXT -->
  <nav
    class="pd-next"
    aria-label={tr.navProjectLabel}
    data-aria-label-alt={altOf(tr.navProjectLabel, trA.navProjectLabel)}
  >
    {prev && (
      <a
        class="pd-nav-link prev"
        href={localePath(locale, `/work/${prev.id}`)}
        data-cursor="open"
      >
        <span class="meta" data-i18n-alt={altOf(tr.prevLabel, trA.prevLabel)}>{tr.prevLabel}</span><span class="t" data-i18n-alt={altOf(prev.name, prevAlt?.name ?? prev.name)}>{prev.name}</span>
      </a>
    )}
    {next && (
      <a
        class="pd-nav-link next"
        href={localePath(locale, `/work/${next.id}`)}
        data-cursor="open"
      >
        <span class="meta" data-i18n-alt={altOf(tr.nextLabel, trA.nextLabel)}>{tr.nextLabel}</span><span class="t" data-i18n-alt={altOf(next.name, nextAlt?.name ?? next.name)}>{next.name}</span>
      </a>
    )}
  </nav>

  <Footer locale={locale} />

  {/* SHOWREEL OVERLAY — reused for the project video (rendered only when present) */}
  {p.video && <Showreel locale={locale} hasVideo={true} />}
</Base>
