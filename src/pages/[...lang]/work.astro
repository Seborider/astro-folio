---
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";
import Media from "../../components/Media.astro";
import { getProjects } from "../../lib/projects";
import { altOf, localePath, localeStaticPaths, otherLocale } from "../../i18n";
import { t } from "../../i18n/ui";

export function getStaticPaths() {
  return localeStaticPaths();
}

const { locale } = Astro.props;
const alt = otherLocale(locale);
const tr = t(locale);
const trA = t(alt);
const projects = await getProjects(locale);
const projectsAlt = await getProjects(alt);

// Derive filter tokens from the human category string — EN and DE keywords,
// since `cat` is translated. Tokens stay locale-independent. (For a CMS,
// prefer an explicit `tags` field over deriving — see README.)
function filtersFor(cat: string): string[] {
  const c = cat.toLowerCase();
  const t: string[] = [];
  if (
    /brand|identity|identität|marke|art direction|packaging|verpackung/.test(c)
  )
    t.push("brand");
  if (/motion|film|title|titel|3d|campaign|kampagne|animation|bewegung/.test(c))
    t.push("motion");
  if (
    /editorial|redaktion|photography|fotografie|exhibition|ausstellung/.test(c)
  )
    t.push("editorial");
  if (/web|webgl|digital/.test(c)) t.push("digital");
  return t.length ? t : ["brand"];
}
---

<Base
  title={tr.workMetaTitle}
  description={tr.workDescription}
  titleAlt={trA.workMetaTitle}
  locale={locale}
>
  <!-- PAGE HERO -->
  <section
    class="phero"
    data-screen-label={tr.sections.workHero}
    data-screen-label-alt={altOf(tr.sections.workHero, trA.sections.workHero)}
  >
    <div class="phero__index meta">
      <span data-scramble-now data-text={tr.workScramble} data-i18n-alt={altOf(tr.workScramble, trA.workScramble)}
        >{tr.workScramble}</span
      ><span class="rule"></span><span
        data-i18n-alt={altOf(`${tr.indexLabel} 02`, `${trA.indexLabel} 02`)}
        >{tr.indexLabel} 02</span
      >
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise data-i18n-alt={altOf(tr.workTitle, trA.workTitle)}>{tr.workTitle}</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft data-i18n-alt={altOf(tr.workLede, trA.workLede)}>{tr.workLede}</p>
      <span class="meta" data-rise-soft
        >( {String(projects.length).padStart(2, "0")}
        <span data-i18n-alt={altOf(tr.projectsCountLabel, trA.projectsCountLabel)}>{tr.projectsCountLabel}</span> )</span
      >
    </div>
  </section>

  <!-- FILTER -->
  <div class="work-filter" id="workFilter">
    <button class="is-active" data-filter="all" data-cursor="open" data-i18n-alt={altOf(tr.filterAll, trA.filterAll)}
      >{tr.filterAll}</button
    >
    <button data-filter="brand" data-cursor="open" data-i18n-alt={altOf(tr.filterBrand, trA.filterBrand)}>{tr.filterBrand}</button>
    <button data-filter="motion" data-cursor="open" data-i18n-alt={altOf(tr.filterMotion, trA.filterMotion)}>{tr.filterMotion}</button>
    <button data-filter="editorial" data-cursor="open" data-i18n-alt={altOf(tr.filterEditorial, trA.filterEditorial)}
      >{tr.filterEditorial}</button
    >
    <button data-filter="digital" data-cursor="open" data-i18n-alt={altOf(tr.filterDigital, trA.filterDigital)}>{tr.filterDigital}</button>
  </div>

  <!-- filter result announcement (WCAG 4.1.3) — both locale units baked in; the
       click handler picks one by document.documentElement.lang, so the count
       announcement follows the in-place EN/DE switch (text is JS-set, not swapped) -->
  <p
    class="sr-only"
    role="status"
    aria-live="polite"
    id="filterStatus"
    data-unit-de={t("de").projectsCountLabel}
    data-unit-en={t("en").projectsCountLabel}
  ></p>

  <!-- PROJECT GRID -->
  <section
    class="proj-grid"
    id="projGrid"
    data-screen-label={tr.sections.projectGrid}
    data-screen-label-alt={altOf(tr.sections.projectGrid, trA.sections.projectGrid)}
  >
    {
      projects.map((p, i) => {
        const wide = i % 5 === 0;
        const tags = filtersFor(p.cat).join(" ");
        const pA = projectsAlt[i];
        return (
          <a
            class={`proj${wide ? " is-wide" : ""}`}
            href={localePath(locale, `/work/${p.id}`)}
            data-cursor="open"
            data-cat={tags}
            data-reveal
          >
            <div class="proj__media">
              <span class="proj__no">{String(i + 1).padStart(2, "0")}</span>
              <Media src={p.cover} label={p.name} />
            </div>
            <div class="proj__meta">
              <div>
                <div class="proj__name" data-scramble data-i18n-alt={altOf(p.name, pA?.name ?? p.name)}>
                  {p.name}
                </div>
                <div class="proj__cat" data-i18n-alt={altOf(p.cat, pA?.cat ?? p.cat)}>{p.cat}</div>
              </div>
              <div class="proj__yr">{p.yr}</div>
            </div>
          </a>
        );
      })
    }
  </section>

  <Footer locale={locale} />
</Base>

<script is:inline>
  // project filter
  (function () {
    const btns = document.querySelectorAll(".work-filter button");
    const projs = document.querySelectorAll(".proj");
    const status = document.getElementById("filterStatus");
    btns.forEach((b) => {
      b.addEventListener("click", () => {
        btns.forEach((x) => x.classList.remove("is-active"));
        b.classList.add("is-active");
        const f = b.dataset.filter;
        let shown = 0;
        projs.forEach((p) => {
          const show =
            f === "all" || (p.dataset.cat || "").split(" ").includes(f);
          p.classList.toggle("is-hidden", !show);
          if (show) shown++;
        });
        if (status) {
          const en = document.documentElement.lang === "en";
          status.textContent =
            shown + " " + (en ? status.dataset.unitEn : status.dataset.unitDe);
        }
        if (window.ScrollTrigger) window.ScrollTrigger.refresh();
      });
    });
  })();
</script>
