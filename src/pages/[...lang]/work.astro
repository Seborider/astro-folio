---
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";
import Media from "../../components/Media.astro";
import { getProjects } from "../../lib/projects";
import { localePath, localeStaticPaths } from "../../i18n";
import { t } from "../../i18n/ui";

export function getStaticPaths() {
  return localeStaticPaths();
}

const { locale } = Astro.props;
const tr = t(locale);
const projects = await getProjects(locale);

// Derive filter tokens from the human category string ã EN and DE keywords,
// since `cat` is translated. Tokens stay locale-independent. (For a CMS,
// prefer an explicit `tags` field over deriving ã see README.)
function filtersFor(cat: string): string[] {
  const c = cat.toLowerCase();
  const t: string[] = [];
  if (/brand|identity|identitûÊt|marke|art direction|packaging|verpackung/.test(c)) t.push("brand");
  if (/motion|film|title|titel|3d|campaign|kampagne|animation|bewegung/.test(c)) t.push("motion");
  if (/editorial|redaktion|photography|fotografie|exhibition|ausstellung/.test(c)) t.push("editorial");
  if (/web|webgl|digital/.test(c)) t.push("digital");
  return t.length ? t : ["brand"];
}
---

<Base title={tr.workMetaTitle} description={tr.workDescription} locale={locale}>
  <!-- PAGE HERO -->
  <section class="phero" data-screen-label="Work hero">
    <div class="phero__index meta">
      <span data-scramble-now data-text={tr.workScramble}>{tr.workScramble}</span><span class="rule"></span><span>Index 02</span>
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise>{tr.workTitle}</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft>{tr.workLede}</p>
      <span class="meta" data-rise-soft>( {String(projects.length).padStart(2, "0")} {tr.projectsCountLabel} )</span>
    </div>
  </section>

  <!-- FILTER -->
  <div class="work-filter" id="workFilter">
    <button class="is-active" data-filter="all" data-cursor="open">{tr.filterAll}</button>
    <button data-filter="brand" data-cursor="open">{tr.filterBrand}</button>
    <button data-filter="motion" data-cursor="open">{tr.filterMotion}</button>
    <button data-filter="editorial" data-cursor="open">{tr.filterEditorial}</button>
    <button data-filter="digital" data-cursor="open">{tr.filterDigital}</button>
  </div>

  <!-- PROJECT GRID -->
  <section class="proj-grid" id="projGrid" data-screen-label="Project grid">
    {projects.map((p, i) => {
      const wide = i % 5 === 0;
      const tags = filtersFor(p.cat).join(" ");
      return (
        <a class={`proj${wide ? " is-wide" : ""}`} href={localePath(locale, `/work/${p.id}`)} data-cursor="open" data-cat={tags} data-reveal>
          <div class="proj__media">
            <span class="proj__no">{String(i + 1).padStart(2, "0")}</span>
            <Media src={p.cover} label={`${p.name}${wide ? " ôñ 21:9" : ""}`} />
          </div>
          <div class="proj__meta">
            <div>
              <div class="proj__name" data-scramble>{p.name}</div>
              <div class="proj__cat">{p.cat}</div>
            </div>
            <div class="proj__yr">{p.yr}</div>
          </div>
        </a>
      );
    })}
  </section>

  <Footer locale={locale} />
</Base>

<script is:inline>
  // project filter
  (function () {
    const btns = document.querySelectorAll(".work-filter button");
    const projs = document.querySelectorAll(".proj");
    btns.forEach((b) => {
      b.addEventListener("click", () => {
        btns.forEach((x) => x.classList.remove("is-active"));
        b.classList.add("is-active");
        const f = b.dataset.filter;
        projs.forEach((p) => {
          const show = f === "all" || (p.dataset.cat || "").split(" ").includes(f);
          p.classList.toggle("is-hidden", !show);
        });
        if (window.ScrollTrigger) window.ScrollTrigger.refresh();
      });
    });
  })();
</script>
