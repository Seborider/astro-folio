---
import LegalPage from "../../components/LegalPage.astro";
import { getDatenschutzPage } from "../../lib/legal";
import { localeStaticPaths, otherLocale } from "../../i18n";
import { t } from "../../i18n/ui";

export function getStaticPaths() {
  return localeStaticPaths();
}

const { locale } = Astro.props;
const alt = otherLocale(locale);
const page = await getDatenschutzPage(locale);
const pageAlt = await getDatenschutzPage(alt);
---

<LegalPage
  locale={locale}
  page={page}
  pageAlt={pageAlt}
  sideLabel={t(locale).navDatenschutz}
  sideLabelAlt={t(alt).navDatenschutz}
/>
