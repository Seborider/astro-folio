---
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";
import PheroCanvas from "../../components/PheroCanvas.astro";
import { getDatenschutzPage } from "../../lib/datenschutz";
import { altOf, localeStaticPaths, otherLocale } from "../../i18n";
import { t } from "../../i18n/ui";

export function getStaticPaths() {
  return localeStaticPaths();
}

const { locale } = Astro.props;
const alt = otherLocale(locale);
const tr = t(locale);
const trA = t(alt);
const page = await getDatenschutzPage(locale);
const pageAlt = await getDatenschutzPage(alt);
const scramble = `( ${page.title} )`;
const scrambleAlt = `( ${pageAlt.title} )`;
---

<Base
  title={page.metaTitle}
  description={page.lede}
  titleAlt={pageAlt.metaTitle}
  locale={locale}
>
  <!-- PAGE HERO -->
  <section
    class="phero"
    data-screen-label={page.title}
    data-screen-label-alt={altOf(page.title, pageAlt.title)}
  >
    <PheroCanvas locale={locale} />
    <div class="phero__index meta">
      <span data-scramble-now data-text={scramble} data-i18n-alt={altOf(scramble, scrambleAlt)}
        >{scramble}</span
      ><span class="rule"></span><span>{tr.indexLabel}</span>
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise data-i18n-alt={altOf(page.title, pageAlt.title)}>{page.title}</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft data-i18n-alt={altOf(page.lede, pageAlt.lede)}>{page.lede}</p>
    </div>
  </section>

  <!-- BODY -->
  <section class="about-cols">
    <div class="about-cols__label meta" data-i18n-alt={altOf(`( ${tr.navDatenschutz} )`, `( ${trA.navDatenschutz} )`)}>( {tr.navDatenschutz} )</div>
    <div class="about-cols__body">
      {page.body.map((p, i) => <p set:html={p} data-i18n-html data-i18n-alt={altOf(p, pageAlt.body[i] ?? p)} />)}
    </div>
  </section>

  <Footer locale={locale} />
</Base>
