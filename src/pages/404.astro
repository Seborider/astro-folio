---
/**
 * 404.astro — static not-found page (built to /404.html, served by the host
 * for any unmatched route). A single static file can only ship one locale, so
 * this is German-primary (the site default) with an English sub-line. It reuses
 * the .phero layout and the page-hero rise/scramble wired by core.js.
 */
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
import { DEFAULT_LOCALE, pageTitle } from "../i18n";
import { t } from "../i18n/ui";

const tr = t(DEFAULT_LOCALE);
---

<Base
  title={pageTitle("404")}
  description={tr.notFoundDescription}
  locale={DEFAULT_LOCALE}
  noindex={true}
>
  <section class="phero notfound" data-screen-label="404">
    <div class="phero__index meta">
      <span data-scramble-now data-text={tr.notFoundScramble}
        >{tr.notFoundScramble}</span
      >
      <span class="rule"></span>
      <span>{tr.notFoundLabel}</span>
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise>404</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft>
        {tr.notFoundLede}
      </p>
      <span class="meta" data-rise-soft lang="en">{tr.notFoundSubMeta}</span>
    </div>
    <nav class="notfound__links" data-rise-soft>
      <a href="/" data-cursor="home">{tr.notFoundHome}</a>
      <a href="/work/" data-cursor="view">{tr.notFoundWork}</a>
    </nav>
  </section>

  <Footer locale={DEFAULT_LOCALE} />
</Base>
