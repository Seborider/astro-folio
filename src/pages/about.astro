---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
---

<Base title="About — Juno Vestergaard">
  <!-- PAGE HERO -->
  <section class="phero" data-screen-label="About hero">
    <div class="phero__index meta">
      <span data-scramble-now data-text="( About )">( About )</span><span class="rule"></span><span>Index 01</span>
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise>About</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft>Design &amp; art director working between brand, motion and the printed page.</p>
      <span class="meta" data-rise-soft>( Copenhagen — est. 2014 )</span>
    </div>
  </section>

  <!-- INTRO QUOTE -->
  <section class="about-intro">
    <blockquote class="about-intro__quote reveal-lines">
      <span class="line"><span>I shape the space</span></span>
      <span class="line"><span>between images,</span></span>
      <span class="line"><span>where rhythm turns</span></span>
      <span class="line"><span>to <em>meaning</em>.</span></span>
    </blockquote>
  </section>

  <!-- BIO -->
  <section class="about-cols">
    <div class="about-cols__label meta">( Bio )</div>
    <div class="about-cols__body">
      <p>Juno Vestergaard is a Copenhagen-based design and art director with a decade of practice spanning identity systems, motion, and editorial. The work is led by typography and pacing — treating a brand less as a logo and more as a tempo that recurs across every surface.</p>
      <p><span class="dim">Previously</span> design lead at a Scandinavian studio and an independent for cultural institutions, fashion houses and technology brands. Current focus: long-form brand worlds and the moving image.</p>
      <p><span class="dim">Approach</span> — slow looking, sharp type, generous white space, and the conviction that restraint is its own kind of noise.</p>
    </div>
  </section>

  <!-- PORTRAIT -->
  <section class="about-portrait">
    <div class="frame"><div class="placeholder ph-motion"><span>Portrait / studio — drop image here</span></div></div>
    <div class="cap meta"><span>Studio, Vesterbro</span><span>2026</span></div>
  </section>

  <!-- CAPABILITIES -->
  <section class="idx-list">
    <div class="idx-list__head">
      <h2>Capabilities</h2>
      <span class="meta">( 01 — 05 )</span>
    </div>
    <div class="idx-row" data-reveal><span class="n">01</span><span class="t" data-scramble>Brand systems</span><span class="d">Identity, naming, voice, guidelines, rollout</span></div>
    <div class="idx-row" data-reveal><span class="n">02</span><span class="t" data-scramble>Art direction</span><span class="d">Campaigns, photography, casting, set</span></div>
    <div class="idx-row" data-reveal><span class="n">03</span><span class="t" data-scramble>Motion</span><span class="d">Title design, brand films, sound partners</span></div>
    <div class="idx-row" data-reveal><span class="n">04</span><span class="t" data-scramble>Editorial</span><span class="d">Books, catalogues, type design, print craft</span></div>
    <div class="idx-row" data-reveal><span class="n">05</span><span class="t" data-scramble>Digital</span><span class="d">Sites, WebGL, prototypes with dev partners</span></div>
  </section>

  <!-- RECOGNITION -->
  <section class="idx-list" style="margin-top:clamp(60px,10vh,120px)">
    <div class="idx-list__head">
      <h2>Recognition</h2>
      <span class="meta">( Selected )</span>
    </div>
    <div class="idx-row" data-reveal><span class="n">—</span><span class="t" data-scramble>Awwwards</span><span class="d">Site of the Day × 3, Developer Award</span></div>
    <div class="idx-row" data-reveal><span class="n">—</span><span class="t" data-scramble>D&amp;AD</span><span class="d">Wood Pencil, Branding</span></div>
    <div class="idx-row" data-reveal><span class="n">—</span><span class="t" data-scramble>Type Directors Club</span><span class="d">Certificate of Excellence</span></div>
    <div class="idx-row" data-reveal><span class="n">—</span><span class="t" data-scramble>Lectures</span><span class="d">CPH Design Week, Typojanchi, OFFF</span></div>
  </section>

  <Footer />
</Base>
