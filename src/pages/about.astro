---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
import Media from "../components/Media.astro";
import { getAboutPage } from "../lib/site";

const about = await getAboutPage();
const capRange = `( 01 — ${String(about.capabilities.length).padStart(2, "0")} )`;
---

<Base title={about.metaTitle}>
  <!-- PAGE HERO -->
  <section class="phero" data-screen-label="About hero">
    <div class="phero__index meta">
      <span data-scramble-now data-text="( About )">( About )</span><span class="rule"></span><span>Index 01</span>
    </div>
    <h1 class="phero__title">
      <span class="line"><span data-rise>{about.title}</span></span>
    </h1>
    <div class="phero__sub">
      <p class="phero__lede" data-rise-soft>{about.lede}</p>
      <span class="meta" data-rise-soft>{about.subMeta}</span>
    </div>
  </section>

  <!-- INTRO QUOTE -->
  <section class="about-intro">
    <blockquote class="about-intro__quote reveal-lines">
      {about.introQuote.map((line) => (
        <span class="line"><span set:html={line}></span></span>
      ))}
    </blockquote>
  </section>

  <!-- BIO -->
  <section class="about-cols">
    <div class="about-cols__label meta">( Bio )</div>
    <div class="about-cols__body">
      {about.bio.map((t) => <p set:html={t}></p>)}
    </div>
  </section>

  <!-- PORTRAIT -->
  <section class="about-portrait">
    <div class="frame"><Media src={about.portrait} label={about.portraitCaption} /></div>
    <div class="cap meta"><span>{about.portraitCaption}</span><span>{about.portraitYear}</span></div>
  </section>

  <!-- CAPABILITIES -->
  <section class="idx-list">
    <div class="idx-list__head">
      <h2>{about.capabilitiesHeading}</h2>
      <span class="meta">{capRange}</span>
    </div>
    {about.capabilities.map((c, i) => (
      <div class="idx-row" data-reveal><span class="n">{String(i + 1).padStart(2, "0")}</span><span class="t" data-scramble>{c.title}</span><span class="d">{c.detail}</span></div>
    ))}
  </section>

  <!-- RECOGNITION -->
  <section class="idx-list" style="margin-top:clamp(60px,10vh,120px)">
    <div class="idx-list__head">
      <h2>{about.recognitionHeading}</h2>
      <span class="meta">( Selected )</span>
    </div>
    {about.recognition.map((r) => (
      <div class="idx-row" data-reveal><span class="n">—</span><span class="t" data-scramble>{r.title}</span><span class="d">{r.detail}</span></div>
    ))}
  </section>

  <Footer />
</Base>
