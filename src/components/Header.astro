---
/**
 * Header.astro — fixed top bar, identical on every page.
 * Links use Astro's extensionless routes; chrome.js intercepts them
 * for the wipe transition. The mark text comes from siteSettings.
 * The language switcher is an in-place toggle (a <button>, so chrome.js's
 * a[href] wipe leaves it alone): public/scripts/i18n.js swaps the page text
 * client-side. Every localized node carries its alternate in data-i18n-alt
 * (text) or data-*-alt (attributes) for that swap.
 */
import { getSiteSettings } from "../lib/site";
import { altOf, localePath, otherLocale, type Locale } from "../i18n";
import { t } from "../i18n/ui";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const alt = otherLocale(locale);
const s = await getSiteSettings(locale);
const sA = await getSiteSettings(alt);
const tr = t(locale);
const trA = t(alt);
// Switcher label: shows the OTHER locale's code; its alt is this locale's code.
const langLabel = locale === "de" ? "EN" : "DE";
const langLabelAlt = locale === "de" ? "DE" : "EN";
---

<header class="header">
  <a
    class="header__mark"
    href={localePath(locale, "/")}
    data-cursor="home"
    data-i18n-alt={altOf(s.headerMark, sA.headerMark)}>{s.headerMark}</a
  >
  <nav
    class="header__nav"
    aria-label={tr.navPrimaryLabel}
    data-aria-label-alt={altOf(tr.navPrimaryLabel, trA.navPrimaryLabel)}
  >
    <a
      href={localePath(locale, "/work")}
      data-cursor="view"
      data-i18n-alt={altOf(tr.navWork, trA.navWork)}>{tr.navWork}</a
    >
    <a
      href={localePath(locale, "/about")}
      data-cursor="view"
      data-i18n-alt={altOf(tr.navAbout, trA.navAbout)}>{tr.navAbout}</a
    >
    <a
      href={localePath(locale, "/archive")}
      data-cursor="view"
      data-i18n-alt={altOf(tr.navArchive, trA.navArchive)}>{tr.navArchive}</a
    >
    <button
      class="lang-switch"
      data-locale-toggle
      data-cursor="view"
      aria-label={tr.langSwitchLabel}
      data-aria-label-alt={altOf(tr.langSwitchLabel, trA.langSwitchLabel)}
      data-i18n-alt={langLabelAlt}>{langLabel}</button
    >
    <button
      class="theme-toggle"
      data-theme-toggle
      aria-label={tr.themeToggleLabel}
      data-aria-label-alt={altOf(tr.themeToggleLabel, trA.themeToggleLabel)}
      >◐</button
    >
    <button
      class="hero__reset phero__reset"
      type="button"
      aria-label={tr.heroResetLabel}
      data-aria-label-alt={altOf(tr.heroResetLabel, trA.heroResetLabel)}>↺</button
    >
  </nav>
  <button
    class="nav-toggle"
    data-nav-toggle
    aria-controls="navPanel"
    aria-expanded="false"
    aria-label={tr.menuLabel}
    data-aria-label-alt={altOf(tr.menuLabel, trA.menuLabel)}
  >
    <span></span><span></span>
  </button>
</header>

<!-- Mobile nav. Sibling of <header> on purpose: the header's
     mix-blend-mode: difference would invert this solid panel, so it lives
     outside that stacking context. Reuses the same nav links, theme toggle
     and locale switch (order: links → theme → locale). -->
<div class="nav-panel" id="navPanel">
  <nav
    class="nav-panel__nav"
    aria-label={tr.menuLabel}
    data-aria-label-alt={altOf(tr.menuLabel, trA.menuLabel)}
  >
    <a
      href={localePath(locale, "/work")}
      data-cursor="view"
      data-i18n-alt={altOf(tr.navWork, trA.navWork)}>{tr.navWork}</a
    >
    <a
      href={localePath(locale, "/about")}
      data-cursor="view"
      data-i18n-alt={altOf(tr.navAbout, trA.navAbout)}>{tr.navAbout}</a
    >
    <a
      href={localePath(locale, "/archive")}
      data-cursor="view"
      data-i18n-alt={altOf(tr.navArchive, trA.navArchive)}>{tr.navArchive}</a
    >
  </nav>
  <div class="nav-panel__controls">
    <button
      class="theme-toggle"
      data-theme-toggle
      aria-label={tr.themeToggleLabel}
      data-aria-label-alt={altOf(tr.themeToggleLabel, trA.themeToggleLabel)}
      >◐</button
    >
    <button
      class="hero__reset phero__reset"
      type="button"
      aria-label={tr.heroResetLabel}
      data-aria-label-alt={altOf(tr.heroResetLabel, trA.heroResetLabel)}>↺</button
    >
    <button
      class="lang-switch"
      data-locale-toggle
      data-cursor="view"
      aria-label={tr.langSwitchLabel}
      data-aria-label-alt={altOf(tr.langSwitchLabel, trA.langSwitchLabel)}
      data-i18n-alt={langLabelAlt}>{langLabel}</button
    >
  </div>
</div>

<script is:inline>
  (function () {
    const btn = document.querySelector("[data-nav-toggle]");
    const panel = document.getElementById("navPanel");
    if (!btn || !panel) return;
    function setOpen(open) {
      btn.setAttribute("aria-expanded", open ? "true" : "false");
      panel.classList.toggle("is-open", open);
      // hide the custom scrollbar (it sits above the panel) while open
      document.documentElement.classList.toggle("menu-open", open);
    }
    btn.addEventListener("click", function () {
      setOpen(btn.getAttribute("aria-expanded") !== "true");
    });
    panel.addEventListener("click", function (e) {
      // Only nav links navigate away — close as we leave. The locale toggle
      // is a <button> (swaps text in place), so it never matches here and the
      // panel stays open across the switch, mirroring the theme toggle.
      if (!e.target.closest("a")) return;
      setOpen(false);
    });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") setOpen(false);
    });
  })();
</script>
