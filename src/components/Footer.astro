---
/**
 * Footer.astro — site footer.
 * Pass `carousel` (a list of projects) to render the home page's
 * Archive band with the draggable project carousel. Omit it for the
 * lean footer used on inner pages.
 * Contact/socials/copy come from siteSettings (CMS with local defaults).
 */
import Media from "./Media.astro";
import { getSiteSettings } from "../lib/site";
import { altOf, localePath, otherLocale, type Locale } from "../i18n";
import { t } from "../i18n/ui";

interface CarouselItem {
  id: string;
  name: string;
  nameAlt?: string;
  yr: string;
  cover?: string | null; // thumbnail-width cover URL
}
interface Props {
  locale: Locale;
  carousel?: CarouselItem[];
}
const { locale, carousel } = Astro.props;
const alt = otherLocale(locale);
const s = await getSiteSettings(locale);
const sA = await getSiteSettings(alt);
const tr = t(locale);
const trA = t(alt);
---

<footer
  class="footer"
  id={carousel ? "archive" : undefined}
  data-screen-label={tr.sections.contact}
  data-screen-label-alt={altOf(tr.sections.contact, trA.sections.contact)}
>
  {
    carousel && (
      <>
        <div class="footer__head">
          <h2 data-i18n-alt={altOf(s.archiveHeading, sA.archiveHeading)}>
            {s.archiveHeading}
          </h2>
          <span class="meta" id="carCount">
            ( 1 / {String(carousel.length).padStart(2, "0")} )
          </span>
        </div>
        <div class="carousel" id="carousel">
          {carousel.map((p) => (
            <a
              class="carousel__item"
              href={localePath(locale, `/work/${p.id}`)}
              data-cursor="open"
            >
              <div class="carousel__media">
                <Media src={p.cover} label={p.name} />
              </div>
              <div class="carousel__cap">
                <span data-i18n-alt={altOf(p.name, p.nameAlt ?? p.name)}>
                  {p.name}
                </span>
                <span>{p.yr}</span>
              </div>
            </a>
          ))}
        </div>
      </>
    )
  }

  <div class="footer__grid">
    <div class="footer__contact">
      <div class="meta" style="margin-bottom:18px" data-i18n-alt={altOf(s.contactLabel, sA.contactLabel)}>{s.contactLabel}</div>
      <a
        class="big"
        href={`mailto:${s.email}`}
        data-cursor="view"
        data-magnetic
        data-i18n-alt={altOf(s.contactCta, sA.contactCta)}>{s.contactCta}</a
      >
    </div>
    <div class="footer__col">
      <h4 data-i18n-alt={altOf(tr.footSocials, trA.footSocials)}>{tr.footSocials}</h4>
      {
        s.socials.map((soc, i) => (
          <a
            href={soc.url}
            target={soc.url.startsWith("/") ? undefined : "_blank"}
            rel={soc.url.startsWith("/") ? undefined : "noopener noreferrer"}
            data-cursor="view"
            data-i18n-alt={altOf(soc.label, sA.socials[i]?.label ?? soc.label)}
          >
            {soc.label}
          </a>
        ))
      }
    </div>
    <div class="footer__col">
      <h4 data-i18n-alt={altOf(tr.footIndex, trA.footIndex)}>{tr.footIndex}</h4>
      <a href={localePath(locale, "/")} data-cursor="home" data-i18n-alt={altOf(tr.footHome, trA.footHome)}>{tr.footHome}</a>
      <a href={localePath(locale, "/work")} data-cursor="view" data-i18n-alt={altOf(tr.navWork, trA.navWork)}>{tr.navWork}</a>
      <a href={localePath(locale, "/about")} data-cursor="view" data-i18n-alt={altOf(tr.navAbout, trA.navAbout)}>{tr.navAbout}</a
      >
      <a href={localePath(locale, "/archive")} data-cursor="view" data-i18n-alt={altOf(tr.navArchive, trA.navArchive)}
        >{tr.navArchive}</a
      >
      <a href={localePath(locale, "/impressum")} data-cursor="view" data-i18n-alt={altOf(tr.navImpressum, trA.navImpressum)}
        >{tr.navImpressum}</a
      >
      <a href={localePath(locale, "/datenschutz")} data-cursor="view" data-i18n-alt={altOf(tr.navDatenschutz, trA.navDatenschutz)}
        >{tr.navDatenschutz}</a
      >
    </div>
    <div class="footer__col">
      <h4 data-i18n-alt={altOf(tr.footBased, trA.footBased)}>{tr.footBased}</h4>
      <span class="footer__avail"><span class="avail-dot"></span><span data-i18n-alt={altOf(s.availability, sA.availability)}>{
          s.availability
        }</span></span>
      <span data-i18n-alt={altOf(s.location, sA.location)}>{s.location}</span>
      <span data-i18n-alt={altOf(s.timezoneLabel, sA.timezoneLabel)}>{s.timezoneLabel}</span>
      <span id="clock">—</span>
    </div>
  </div>

  <div class="footer__bottom">
    <span data-i18n-alt={altOf(s.copyright, sA.copyright)}>{s.copyright}</span>
    <span data-i18n-alt={altOf(s.colophon, sA.colophon)}>{s.colophon}</span>
    {s.footerNote && <span data-i18n-alt={altOf(s.footerNote, sA.footerNote)}>{s.footerNote}</span>}
  </div>
</footer>
