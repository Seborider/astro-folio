---
/**
 * Footer.astro — site footer.
 * Pass `carousel` (a list of projects) to render the home page's
 * Archive band with the draggable project carousel. Omit it for the
 * lean footer used on inner pages.
 * Contact/socials/copy come from siteSettings (CMS with local defaults).
 */
import Media from "./Media.astro";
import { getSiteSettings } from "../lib/site";
import { localePath, type Locale } from "../i18n";
import { t } from "../i18n/ui";

interface CarouselItem { id: string; name: string; yr: string; cover?: string | null; }
interface Props { locale: Locale; carousel?: CarouselItem[]; }
const { locale, carousel } = Astro.props;
const s = await getSiteSettings(locale);
const tr = t(locale);
---
<footer class="footer" id={carousel ? "archive" : undefined} data-screen-label="Footer">
  {carousel && (
    <>
      <div class="footer__head">
        <h2>{s.archiveHeading}</h2>
        <span class="meta" id="carCount">( 1 / {String(carousel.length).padStart(2, "0")} )</span>
      </div>
      <div class="carousel" id="carousel">
        {carousel.map((p) => (
          <a class="carousel__item" href={localePath(locale, `/work/${p.id}`)} data-cursor="open">
            <div class="carousel__media"><Media src={p.cover} label={p.name} /></div>
            <div class="carousel__cap"><span>{p.name}</span><span>{p.yr}</span></div>
          </a>
        ))}
      </div>
    </>
  )}

  <div class="footer__grid">
    <div class="footer__contact">
      <div class="meta" style="margin-bottom:18px">{s.contactLabel}</div>
      <a class="big" id="emailBtn" href="#" data-email={s.email} data-cursor="copy">{s.contactCta}</a>
    </div>
    <div class="footer__col">
      <h4>{tr.footSocials}</h4>
      {s.socials.map((soc) => (
        <a href={soc.url} data-cursor="view">{soc.label}</a>
      ))}
    </div>
    <div class="footer__col">
      <h4>{tr.footIndex}</h4>
      <a href={localePath(locale, "/")} data-cursor="home">{tr.footHome}</a>
      <a href={localePath(locale, "/work")} data-cursor="view">{tr.navWork}</a>
      <a href={localePath(locale, "/about")} data-cursor="view">{tr.navAbout}</a>
      <a href={localePath(locale, "/archive")} data-cursor="view">{tr.navArchive}</a>
    </div>
    <div class="footer__col">
      <h4>{tr.footBased}</h4>
      <span>{s.location}</span>
      <span>{s.timezoneLabel}</span>
      <span id="clock">—</span>
    </div>
  </div>

  <div class="footer__bottom">
    <span>{s.copyright}</span>
    <span>{s.colophon}</span>
    <span>{s.footerNote}</span>
  </div>
</footer>
