---
/**
 * Base.astro — the shared shell for every page.
 * Renders the WebGL canvas, page-wipe, custom cursor, grain, header,
 * a <main> slot, and loads the motion scripts in the correct order.
 *
 * Props:
 *   title          — document title
 *   description    — per-page meta description (localized by the caller)
 *   titleAlt       — the document title in the OTHER locale, for the in-place
 *                    locale swap of the tab title (see public/scripts/i18n.js)
 *   home           — when true, also loads home.js (loader + showreel + carousel)
 *   locale         — "de" (default) or "en"; drives <html lang> and hreflang
 */
// Self-hosted fonts (no Google CDN — DSGVO: no visitor IP sent to Google,
// cf. LG München I, 20.01.2022, Az. 3 O 17493/20). Weights mirror the old
// CDN request: Instrument Serif 400 + italic, Space Mono 400/700 + 400 italic.
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/400-italic.css";
import "@fontsource/space-mono/700.css";
import "../styles/styles.css";
import Header from "../components/Header.astro";
import { altOf, BRAND, DEFAULT_LOCALE, altLocalePath, type Locale } from "../i18n";
import { serializeJsonLd } from "../lib/jsonld";

interface Props {
  title?: string;
  description?: string;
  titleAlt?: string;
  home?: boolean;
  locale?: Locale;
  image?: string | null; // share-card image; absolute (Sanity) or site-relative
  jsonLd?: object | object[]; // schema.org node(s); see src/lib/jsonld.ts
  noindex?: boolean; // keep the page out of search results (e.g. 404)
}
const {
  title = BRAND,
  description,
  titleAlt,
  home = false,
  locale = DEFAULT_LOCALE,
  image,
  jsonLd,
  noindex = false,
} = Astro.props;
const jsonLdNodes = jsonLd ? [jsonLd].flat() : [];

// hreflang pair — this page in both locales (slugs are shared across locales).
// Normalize the trailing slash so self and alternate URLs match in style.
const path =
  Astro.url.pathname.length > 1
    ? Astro.url.pathname.replace(/\/+$/, "")
    : Astro.url.pathname;
const dePath = locale === "de" ? path : altLocalePath("en", path);
const enPath = locale === "en" ? path : altLocalePath("de", path);

// Absolute URLs for canonical + social cards. new URL() returns an absolute
// `image` (Sanity CDN) unchanged and resolves a site-relative one ("/og.png",
// local covers) against Astro.site. /og.png is the site-wide fallback card.
const canonical = new URL(path, Astro.site);
const shareImage = new URL(image ?? "/og.png", Astro.site);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title data-i18n-alt={altOf(title, titleAlt ?? title)}>{title}</title>
    {noindex && <meta name="robots" content="noindex" />}
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={BRAND} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={shareImage} />
    <meta property="og:locale" content={locale === "de" ? "de_DE" : "en_GB"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={shareImage} />
    {
      jsonLdNodes.map((node) => (
        <script type="application/ld+json" set:html={serializeJsonLd(node)} />
      ))
    }
    <link rel="alternate" hreflang="de" href={new URL(dePath, Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL(enPath, Astro.site)} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(dePath, Astro.site)}
    />
    <!-- locale: runs before first paint. The URL's built locale is the
         default; a stored preference is applied in-place by i18n.js after the
         body parses. Flag a pending swap so CSS can hide the chrome until then
         (no half-translated flash on the header). -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("locale");
          var build = document.documentElement.lang;
          var valid = stored === "de" || stored === "en";
          document.documentElement.dataset.locale = valid ? stored : build;
          // Only arm the chrome-hide for a real locale i18n.js will resolve.
          if (valid && stored !== build)
            document.documentElement.classList.add("i18n-pending");
        } catch (e) {}
      })();
    </script>
    <!-- theme: runs before first paint (no FOUC). Absent attribute = dark. -->
    <script is:inline>
      (function () {
        function apply(theme) {
          if (theme === "light")
            document.documentElement.dataset.theme = "light";
          else delete document.documentElement.dataset.theme;
        }
        let stored = null;
        try {
          stored = localStorage.getItem("theme");
        } catch (e) {}
        apply(
          stored ||
            (matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark"),
        );
        // delegated so it works even though the button parses later
        document.addEventListener("click", function (e) {
          if (!e.target.closest("[data-theme-toggle]")) return;
          const theme =
            document.documentElement.dataset.theme === "light"
              ? "dark"
              : "light";
          apply(theme);
          try {
            localStorage.setItem("theme", theme);
          } catch (e) {}
          window.dispatchEvent(new Event("themechange"));
        });
      })();
    </script>
    <!-- loader: only the cold session load shows it. Mark revisits before
         first paint so CSS hides #loader (no "0" flash, no masked wipe). -->
    <script is:inline>
      try {
        if (sessionStorage.getItem("folio_seen"))
          document.documentElement.classList.add("loader-seen");
        // Browsers with View Transitions own the page transition (see
        // @view-transition in styles.css); flag it so the JS wipe steps aside.
        if (window.CSS && CSS.supports("view-transition-name", "none"))
          document.documentElement.classList.add("vt");
      } catch (e) {}
    </script>
    <!-- View-Transition arrivals fire `pagereveal` before the end-of-body
         motion scripts run, so capture it here (in <head>) and stash the
         inbound transition. core.js reads window.__vt/__vtSeen to sequence the
         hero rise after the wipe (vtRiseIn) finishes. -->
    <script is:inline>
      window.__vtSeen = false;
      window.addEventListener(
        "pagereveal",
        function (e) {
          window.__vt = e.viewTransition || null;
          window.__vtSeen = true;
        },
        { once: true },
      );
    </script>
  </head>
  <body>
    <canvas id="glbg"></canvas>
    <div class="page-wipe"></div>
    <div class="grain"></div>
    <div class="cursor" id="cursor"></div>
    <div class="cursor-label" id="cursorLabel"></div>
    <div class="scrollbar" id="scrollbar" aria-hidden="true">
      <div class="scrollbar__thumb"></div>
    </div>

    <Header locale={locale} />

    <main id="top">
      <slot />
    </main>

    <!-- live section index — core.js fills it from each section's data-screen-label -->
    <div class="section-index meta" id="sectionIndex" aria-hidden="true"></div>

    <!-- floating cover preview (core.js trails it over .work__row / .arch__row) -->
    <div class="work__preview" id="workPreview">
      <img alt="" hidden /><div class="placeholder ph-motion">
        <span>preview</span>
      </div>
    </div>

    <!-- libraries -->
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
    ></script>
    <script is:inline src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"
    ></script>

    <!-- app (order matters) -->
    <script is:inline src="/scripts/webgl-bg.js"></script>
    <script is:inline src="/scripts/chrome.js"></script>
    <!-- i18n before core: apply a stored locale (swap text + data-text) so the
         reveal/scramble animations in core.js play on the correct strings. -->
    <script is:inline src="/scripts/i18n.js"></script>
    <script is:inline src="/scripts/core.js"></script>
    {home && <script is:inline src="/scripts/home.js" />}
  </body>
</html>
