---
/**
 * Base.astro — the shared shell for every page.
 * Renders the WebGL canvas, page-wipe, custom cursor, grain, header,
 * a <main> slot, and loads the motion scripts in the correct order.
 *
 * Props:
 *   title       — document title
 *   description — per-page meta description (localized by the caller)
 *   home        — when true, also loads home.js (loader + showreel + carousel)
 *   locale      — "de" (default) or "en"; drives <html lang> and hreflang
 */
import "../styles/folio.css";
import Header from "../components/Header.astro";
import Tweaks from "../components/Tweaks";
import { DEFAULT_LOCALE, altLocalePath, type Locale } from "../i18n";

interface Props {
  title?: string;
  description?: string;
  home?: boolean;
  locale?: Locale;
}
const { title = "Sebo Mayer", description, home = false, locale = DEFAULT_LOCALE } = Astro.props;

// hreflang pair — this page in both locales (slugs are shared across locales).
// Normalize the trailing slash so self and alternate URLs match in style.
const path = Astro.url.pathname.length > 1 ? Astro.url.pathname.replace(/\/+$/, "") : Astro.url.pathname;
const dePath = locale === "de" ? path : altLocalePath("en", path);
const enPath = locale === "en" ? path : altLocalePath("de", path);
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:locale" content={locale === "de" ? "de_DE" : "en_GB"} />
    <link rel="alternate" hreflang="de" href={new URL(dePath, Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL(enPath, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(dePath, Astro.site)} />
    <!-- theme: runs before first paint (no FOUC). Absent attribute = dark. -->
    <script is:inline>
      (function () {
        function apply(theme) {
          if (theme === "light") document.documentElement.dataset.theme = "light";
          else delete document.documentElement.dataset.theme;
        }
        let stored = null;
        try { stored = localStorage.getItem("theme"); } catch (e) {}
        apply(stored || (matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark"));
        // delegated so it works even though the button parses later
        document.addEventListener("click", function (e) {
          if (!e.target.closest("[data-theme-toggle]")) return;
          const theme = document.documentElement.dataset.theme === "light" ? "dark" : "light";
          apply(theme);
          try { localStorage.setItem("theme", theme); } catch (e) {}
          window.dispatchEvent(new Event("themechange"));
        });
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <canvas id="glbg"></canvas>
    <div class="page-wipe"></div>
    <div class="grain"></div>
    <div class="cursor" id="cursor"></div>
    <div class="cursor-label" id="cursorLabel"></div>

    <Header locale={locale} />

    <main id="top">
      <slot />
    </main>

    <Tweaks client:idle />

    <!-- libraries -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script is:inline src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>

    <!-- app (order matters) -->
    <script is:inline src="/scripts/webgl-bg.js"></script>
    <script is:inline src="/scripts/chrome.js"></script>
    <script is:inline src="/scripts/core.js"></script>
    {home && <script is:inline src="/scripts/home.js"></script>}
  </body>
</html>
